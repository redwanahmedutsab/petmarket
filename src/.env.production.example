# ─────────────────────────────────────────────────────────────────────────────
# Laravel Production Environment
# Copy to .env.production and fill in all values
# NEVER commit this file with real values
# ─────────────────────────────────────────────────────────────────────────────

APP_NAME="Pet Marketplace"
APP_ENV=production
APP_KEY=                          # php artisan key:generate
APP_DEBUG=false
APP_URL=https://api.petmarketplace.com
APP_FRONTEND_URL=https://petmarketplace.com

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ── Database ──────────────────────────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=postgres                  # Docker service name — internal only
DB_PORT=5432
DB_DATABASE=pet_marketplace_prod
DB_USERNAME=petmarket_prod
DB_PASSWORD=                      # Use a strong random password

# ── Cache / Session ───────────────────────────────────────────────────────────
CACHE_STORE=file
FILESYSTEM_DISK=public
QUEUE_CONNECTION=sync
SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true

# ── Mail ──────────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailgun.org        # Replace with your mail provider
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@petmarketplace.com"
MAIL_FROM_NAME="Pet Marketplace"

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=                       # php artisan jwt:secret
JWT_TTL=60
JWT_REFRESH_TTL=20160

# ── CORS ─────────────────────────────────────────────────────────────────────
# Update config/cors.php allowed_origins to match

# ── Social OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://yourdomain.com/api/auth/social/google/callback

FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI=https://yourdomain.com/api/auth/social/facebook/callback

FRONTEND_URL=https://yourdomain.com
